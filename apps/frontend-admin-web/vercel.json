{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && corepack pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && corepack pnpm --filter @petwell/frontend-admin-web build",
  "redirects": [
    {
      "source": "/",
      "destination": "/admin/login",
      "permanent": false
    }
  ]
}

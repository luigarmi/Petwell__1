COMPOSE_PROJECT_NAME=petwell
NODE_ENV=production

# Public URLs. Use your real HTTPS domain.
PUBLIC_APP_URL=https://petwell.example.com
ADMIN_APP_URL=https://petwell.example.com/admin
API_PUBLIC_URL=https://petwell.example.com/api
NEXT_PUBLIC_API_URL=/api
CORS_ORIGIN=https://petwell.example.com

# Generate strong unique values before deploying:
#   openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-64-hex-chars
JWT_REFRESH_SECRET=replace-with-another-64-hex-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
FIELD_ENCRYPTION_KEY=replace-with-64-hex-chars

# Internal database credentials used by the production compose override.
POSTGRES_USER=petwell
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# Internal RabbitMQ credentials.
RABBITMQ_DEFAULT_USER=petwell
RABBITMQ_DEFAULT_PASS=replace-with-strong-rabbitmq-password

# Internal MinIO credentials.
MINIO_ROOT_USER=petwellminio
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_BUCKET=petwell-assets

# SMTP provider for real email delivery.
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=replace-with-smtp-user
MAIL_PASS=replace-with-smtp-password
MAIL_FROM=no-reply@petwell.example.com

# Use mock until real payment credentials and webhook URLs are configured.
PAYMENT_PROVIDER=mock
PAYMENT_CURRENCY=COP
WOMPI_SANDBOX_PUBLIC_KEY=
WOMPI_SANDBOX_PRIVATE_KEY=
WOMPI_SANDBOX_INTEGRITY_SECRET=
WOMPI_SANDBOX_EVENTS_SECRET=
WOMPI_PRODUCTION_PUBLIC_KEY=
WOMPI_PRODUCTION_PRIVATE_KEY=
WOMPI_PRODUCTION_INTEGRITY_SECRET=
WOMPI_PRODUCTION_EVENTS_SECRET=
MERCADOPAGO_SANDBOX_ACCESS_TOKEN=
MERCADOPAGO_SANDBOX_WEBHOOK_SECRET=
MERCADOPAGO_PRODUCTION_ACCESS_TOKEN=
MERCADOPAGO_PRODUCTION_WEBHOOK_SECRET=

# Use mock until the real video provider is configured.
TELEMED_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
DAILY_API_KEY=

# Optional external host ports. Keep observability private unless protected.
HTTP_PORT=80
GRAFANA_PORT=127.0.0.1:3009
PROMETHEUS_PORT=127.0.0.1:9090
LOKI_PORT=127.0.0.1:3100
